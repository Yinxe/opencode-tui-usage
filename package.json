{
  "name": "@Yinxe/opencode-tui-usage",
  "version": "0.0.4",
  "description": "OpenCode TUI 额度显示插件 - 在侧边栏显示用量和额度信息",
  "repository": "github:Yinxe/opencode-tui-usage",
  "type": "module",
  "oc-plugin": [
    "tui"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "default": "./dist/tui.jsx"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "echo test"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "opencode-tui",
    "quota",
    "usage"
  ],
  "author": "Yinxe",
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.0"
  },
  "dependencies": {
    "@opentui/core": "^0.2.2",
    "@opentui/solid": "^0.2.2",
    "solid-js": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
